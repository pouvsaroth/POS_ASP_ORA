        <!-- ================= SIDEBAR ================= -->
        <div id="sidebar" class="sidebar bg-light border-end p-3">

            <h5 class="mb-3">Menu</h5>

            @{
                var controller = ViewContext.RouteData.Values["controller"]?.ToString();

                var productOpen =
                    controller == "Product" ||
                    controller == "ProductCategory";

                var accountOpen =
                controller == "IncomeType"
                
                ;
            }


            <ul class="nav flex-column">

                <!-- Dashboard -->
                <li class="nav-item">
                    <a class="nav-link @(controller=="Home"?"active":"")"
                    asp-controller="Home"
                    asp-action="Index">

                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>

                    </a>
                </li>


                <!-- POS -->
                <li class="nav-item">
                    <a class="nav-link @(controller=="POS"?"active":"")"
                    asp-controller="POS"
                    asp-action="Index">

                        <i class="bi bi-cart"></i>
                        <span>POS</span>

                    </a>
                </li>


                <!-- Products -->
                <li class="nav-item">
                   
                    <a class="nav-link d-flex justify-content-between align-items-center"
                    data-bs-toggle="collapse"
                    href="#productMenu">

                        <span>
                            <i class="bi bi-box"></i>
                            Products
                        </span>

                        <i class="bi bi-chevron-down"></i>

                    </a>

                    <div class="collapse @(productOpen ? "show" : "")" id="productMenu">

                        <ul class="nav flex-column ms-3">

                            <li class="nav-item">
                                <a class="nav-link @(controller=="Product"?"active":"")"
                                asp-controller="Product"
                                asp-action="Product">
                                    Product List
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(controller=="ProductCategory"?"active":"")"
                                asp-controller="ProductCategory"
                                asp-action="ProductCategory">
                                    Product Category
                                </a>
                            </li>

                        </ul>


                    </div>

                </li>
                <li class="nav-item">
                    <ul class="nav flex-column">
                        <!-- Other existing menu items -->

                        <!-- Account Menu -->
                        <li class="nav-item">

                            <a class="nav-link d-flex justify-content-between align-items-center"
                               data-bs-toggle="collapse"
                               href="#accountMenu">

                                <span>
                                    <i class="bi bi-person-circle"></i>
                                    Account
                                </span>

                                <i class="bi bi-chevron-down"></i>

                            </a>

                            <div class="collapse @(accountOpen ? "show" : "")" id="accountMenu">

                                <ul class="nav flex-column ms-3">

                                    <li class="nav-item">
                                        <a class="nav-link @(controller=="IncomeType"?"active":"")"
                                           asp-controller="IncomeType"
                                           asp-action="IncomeType">
                                            <i class="bi bi-cash"></i>
                                            Income Type
                                        </a>
                                    </li>
                                </ul>

                            </div>

                        </li>



               
 
<!-- Sales -->
