<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/POS_ASP_ORA.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-light bg-white shadow-sm px-3">

        <!-- Logo + Title -->
        <div class="d-flex align-items-center">
            <img src="~/images/vorakchuncoffeelogo.png" alt="Logo" style="height:40px; width:40px; object-fit:cover;" class="me-2" />
            <span class="fw-bold">Vorakchun Coffee</span>
        </div>

        <!-- Right Side -->
        <div class="d-flex ms-auto">
            @if (User.Identity.IsAuthenticated)
            {
                <span class="me-3">Hello, @User.Identity.Name</span>

                <a class="btn btn-outline-danger me-2" asp-controller="Authentication" asp-action="Logout">
                    Logout
                </a>
            }
            else
            {
                <a class="btn btn-outline-primary me-2" asp-controller="Authentication" asp-action="Login">
                    Sign In
                </a>

                <a class="btn btn-primary" asp-controller="Authentication" asp-action="Register">
                    Sign Up
                </a>
            }
        </div>

    </nav>

    <!-- Main Layout -->
    <div class="d-flex">

        <!-- Sidebar -->
        <div class="bg-light border-end p-3" style="width: 220px; height: 100vh;">
    <h5>Menu</h5>

    <ul class="nav flex-column">

        <li class="nav-item">
            <a class="nav-link" asp-controller="Home" asp-action="Index">
                Dashboard
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link text-primary" asp-controller="POS" asp-action="Index">
                POS
            </a>
        </li>

        <!-- Products with Sub Menu -->
        <li class="nav-item">

            <a class="nav-link d-flex justify-content-between align-items-center"
               data-bs-toggle="collapse"
               href="#productMenu"
               role="button">

                Products
                <i class="bi bi-chevron-down"></i>
            </a>

            <div class="collapse" id="productMenu">
                <ul class="nav flex-column ms-3">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Product"
                           asp-action="Product">
                            Product List
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="ProductCategory"
                           asp-action="Index">
                            Product Category
                        </a>
                    </li>

                </ul>
            </div>

        </li>

        <li class="nav-item">
            <a class="nav-link" asp-controller="Sales" asp-action="Index">
                Sales
            </a>
        </li>

    </ul>
</div>

        <!-- Content -->
        <div class="flex-grow-1 p-3">
            @RenderBody()
        </div>

    </div>
</body>
</html>
