<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>@ViewData["Title"]</title>

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<link rel="stylesheet" href="~/POS_ASP_ORA.styles.css" asp-append-version="true" />

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>

</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-brown shadow-sm px-3">

<button class="btn" id="toggleSidebar">
<i class="bi bi-list"></i>
</button>

<div class="d-flex align-items-center">
<img src="~/images/vorakchuncoffeelogo.png"
style="height:40px;width:40px;object-fit:cover"
class="me-2" />

<span class="fw-bold text-white">Vorakchun Coffee</span>
</div>

<div class="ms-auto d-flex align-items-center">
    <!-- Date Time -->
    <span id="datetime" class="me-4"></span>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="dropdown me-3">
            <a class="d-flex align-items-center text-white text-decoration-none dropdown-toggle"
                href="#"
                id="userDropdown"
                data-bs-toggle="dropdown"
                aria-expanded="false">

                <img src="~/images/user.gif"
                        style="width:35px;height:35px;border-radius:50%;object-fit:cover"
                        class="me-2" />

                <span>@User.Identity.Name</span>
            </a>

            <ul class="dropdown-menu dropdown-menu-end shadow">
                <li>
                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                        <i class="bi bi-person me-2"></i> Update Profile
                    </a>
                </li>

                <li>
                    <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">
                        <i class="bi bi-key me-2"></i> Change Password
                    </a>
                </li>

                <li><hr class="dropdown-divider"></li>

                <li>
                    <a class="dropdown-item text-danger"
                        asp-controller="Authentication"
                        asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                    </a>
                </li>
            </ul>
        </div>
    }
    else
    {

    <button class="btn btn-outline-light me-2" data-bs-toggle="modal" data-bs-target="#loginModal">
        Sign In
    </button>
    <button class="btn btn-light" data-bs-toggle="modal" data-bs-target="#registerModal">
        Sign Up
    </button>
}

</div>
</nav>


<!-- MAIN LAYOUT -->
<div class="d-flex">

    <!-- SIDEBAR -->
    <div id="sidebar" class="sidebar bg-light border-end">
    

        <ul class="nav flex-column">
                    @using Newtonsoft.Json
                    @using POS_ASP_ORA.Models

                    @{
                        var controller = ViewContext.RouteData.Values["controller"]?.ToString();

                        var menuJson = Context.Session.GetString("Menu");

                        var menus = string.IsNullOrEmpty(menuJson)
                        ? new List<MenuModel>()
                        : JsonConvert.DeserializeObject<List<MenuModel>>(menuJson);
                    }

                    <ul class="nav flex-column">

                        @foreach (var parent in menus)
                        {
                            var isActiveParent = parent.Children.Any(c => c.Controller == controller);

                            if (parent.Children.Any())
                            {
                                <!-- Parent Menu -->
                                <li class="nav-item">

                                    <a class="nav-link d-flex justify-content-between align-items-center"
                                       data-bs-toggle="collapse"
                                       href="#menu_@parent.Id">

                                        <span>
                                            <i class="bi @parent.Icon"></i>
                                            <span class="menu-text">@parent.Name</span>
                                        </span>

                                        <i class="bi bi-chevron-down"></i>
                                    </a>

                                    <div class="collapse @(isActiveParent ? "show" : "")" id="menu_@parent.Id">
                                        <ul class="nav flex-column ms-3">

                                            @foreach (var child in parent.Children)
                                            {
                                                <li class="nav-item">
                                                    <a class="nav-link @(controller == child.Controller ? "active" : "")"
                                                       asp-controller="@child.Controller"
                                                       asp-action="@child.Action">

                                                        @child.Name
                                                    </a>
                                                </li>
                                            }

                                        </ul>
                                    </div>

                                </li>
                            }
                            else
                            {
                                <!-- Single Menu -->
                                <li class="nav-item">
                                    <a class="nav-link @(controller == parent.Controller ? "active" : "")"
                                       asp-controller="@parent.Controller"
                                       asp-action="@parent.Action">

                                        <i class="bi @parent.Icon"></i>
                                        <span class="menu-text">@parent.Name</span>
                                    </a>
                                </li>
                            }
                        }

                    </ul>

        </ul>

    </div>


<!-- PAGE CONTENT -->
<div class="flex-grow-1 p-3">

@RenderBody()

</div>

</div>


<!-- SCRIPTS -->

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
 <script src="~/js/AlertMessage.js"></script>

@RenderSection("Scripts", required: false)

<partial name="_AlertMessage" />
<partial name="_LoginModal" />
<partial name="_RegisterModal" />


<script>

document.getElementById("toggleSidebar").onclick = function(){

var sidebar = document.getElementById("sidebar");

sidebar.classList.toggle("collapsed");

}

var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))

tooltipTriggerList.map(function (tooltipTriggerEl) {

return new bootstrap.Tooltip(tooltipTriggerEl)

})

//Date  and time
function updateTime() {
    const now = new Date();
    document.getElementById("datetime").innerText =
        "Date: " + now.toISOString().slice(0,10) +
        " Time: " + now.toLocaleTimeString();
}
setInterval(updateTime, 1000);
updateTime();
</script>

</body>
</html>