<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>@ViewData["Title"]</title>

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<link rel="stylesheet" href="~/POS_ASP_ORA.styles.css" asp-append-version="true" />

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-brown shadow-sm px-3">

<button class="btn" id="toggleSidebar">
<i class="bi bi-list"></i>
</button>

<div class="d-flex align-items-center">
<img src="~/images/vorakchuncoffeelogo.png"
style="height:40px;width:40px;object-fit:cover"
class="me-2" />

<span class="fw-bold text-white">Vorakchun Coffee</span>
</div>

<div class="ms-auto d-flex align-items-center">

@if (User.Identity.IsAuthenticated)
{
<span class="me-3 text-white">Hello, @User.Identity.Name</span>

<a class="btn btn-outline-danger"
asp-controller="Authentication"
asp-action="Logout">
Logout
</a>
}
else
{
<a class="btn btn-outline-light me-2"
asp-controller="Authentication"
asp-action="Login">
Sign In
</a>

<a class="btn btn-light"
asp-controller="Authentication"
asp-action="Register">
Sign Up
</a>
}

</div>
</nav>


<!-- MAIN LAYOUT -->
<div class="d-flex">

<!-- SIDEBAR -->
<div id="sidebar" class="sidebar bg-light border-end">

@{
var controller = ViewContext.RouteData.Values["controller"]?.ToString();

var productOpen =
controller == "Product" ||
controller == "ProductCategory";

var accountOpen =
controller == "IncomeType";
}

<ul class="nav flex-column">

<!-- Dashboard -->
<li class="nav-item">
<a class="nav-link @(controller=="Home"?"active":"")"
asp-controller="Home"
asp-action="Index"
data-bs-toggle="tooltip"
data-bs-placement="right"
title="Dashboard">

<i class="bi bi-speedometer2"></i>
<span class="menu-text">Dashboard</span>

</a>
</li>


<!-- POS -->
<li class="nav-item">
<a class="nav-link @(controller=="POS"?"active":"")"
asp-controller="POS"
asp-action="Index"
data-bs-toggle="tooltip"
data-bs-placement="right"
title="POS">

<i class="bi bi-cart"></i>
<span class="menu-text">POS</span>

</a>
</li>


<!-- PRODUCTS -->
<li class="nav-item">

<a class="nav-link d-flex justify-content-between align-items-center"
data-bs-toggle="collapse"
href="#productMenu"
title="Products">

<span>
<i class="bi bi-box"></i>
<span class="menu-text">Products</span>
</span>

<i class="bi bi-chevron-down"></i>

</a>

<div class="collapse @(productOpen ? "show" : "")" id="productMenu">

<ul class="nav flex-column ms-3">

<li class="nav-item">
<a class="nav-link @(controller=="Product"?"active":"")"
asp-controller="Product"
asp-action="Product">
Product List
</a>
</li>

<li class="nav-item">
<a class="nav-link @(controller=="ProductCategory"?"active":"")"
asp-controller="ProductCategory"
asp-action="ProductCategory">
Product Category
</a>
</li>

</ul>

</div>

</li>


<!-- ACCOUNT -->
<li class="nav-item">

<a class="nav-link d-flex justify-content-between align-items-center"
data-bs-toggle="collapse"
href="#accountMenu"
title="Account">

<span>
<i class="bi bi-person-circle"></i>
<span class="menu-text">Account</span>
</span>

<i class="bi bi-chevron-down"></i>

</a>

<div class="collapse @(accountOpen ? "show" : "")" id="accountMenu">

<ul class="nav flex-column ms-3">

<li class="nav-item">
<a class="nav-link @(controller=="IncomeType"?"active":"")"
asp-controller="IncomeType"
asp-action="IncomeType">

<i class="bi bi-cash"></i>
Income Type

</a>
</li>

</ul>

</div>

</li>


<!-- SALES -->
<li class="nav-item">
<a class="nav-link @(controller=="Sales"?"active":"")"
asp-controller="Sales"
asp-action="Index"
data-bs-toggle="tooltip"
data-bs-placement="right"
title="Sales">

<i class="bi bi-cash"></i>
<span class="menu-text">Sales</span>

</a>
</li>

</ul>

</div>


<!-- PAGE CONTENT -->
<div class="flex-grow-1 p-3">

@RenderBody()

</div>

</div>


<!-- SCRIPTS -->

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
 <script src="~/js/AlertMessage.js"></script>

@RenderSection("Scripts", required: false)

<partial name="_AlertMessage" />


<script>

document.getElementById("toggleSidebar").onclick = function(){

var sidebar = document.getElementById("sidebar");

sidebar.classList.toggle("collapsed");

}

var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))

tooltipTriggerList.map(function (tooltipTriggerEl) {

return new bootstrap.Tooltip(tooltipTriggerEl)

})



</script>

</body>
</html>