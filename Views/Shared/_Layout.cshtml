<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/POS_ASP_ORA.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>

<!-- ================= NAVBAR ================= -->
<nav class="navbar navbar-light bg-white shadow-sm px-3">

    <!-- Sidebar Toggle -->
    <button class="btn btn-light me-2" id="toggleSidebar">
        <i class="bi bi-list"></i>
    </button>

    <!-- Logo -->
    <div class="d-flex align-items-center">
        <img src="~/images/vorakchuncoffeelogo.png"
             style="height:40px;width:40px;object-fit:cover"
             class="me-2" />

        <span class="fw-bold">Vorakchun Coffee</span>
    </div>

    <!-- Right Side -->
    <div class="ms-auto d-flex">

        @if (User.Identity.IsAuthenticated)
        {
            <span class="me-3">Hello, @User.Identity.Name</span>

            <a class="btn btn-outline-danger"
               asp-controller="Authentication"
               asp-action="Logout">
                Logout
            </a>
        }
        else
        {
            <a class="btn btn-outline-primary me-2"
               asp-controller="Authentication"
               asp-action="Login">
                Sign In
            </a>

            <a class="btn btn-primary"
               asp-controller="Authentication"
               asp-action="Register">
                Sign Up
            </a>
        }

    </div>

</nav>

<!-- ================= MAIN LAYOUT ================= -->
<div class="d-flex">

<!-- ================= SIDEBAR ================= -->
<div id="sidebar" class="sidebar bg-light border-end p-3">

<h5 class="mb-3">Menu</h5>

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();

    var productOpen =
        controller == "Product" ||
        controller == "ProductCategory";
}

<ul class="nav flex-column">

<!-- Dashboard -->
<li class="nav-item">
<a class="nav-link @(controller=="Home"?"active":"")"
   asp-controller="Home"
   asp-action="Index">

<i class="bi bi-speedometer2"></i>
<span>Dashboard</span>

</a>
</li>


<!-- POS -->
<li class="nav-item">
<a class="nav-link @(controller=="POS"?"active":"")"
   asp-controller="POS"
   asp-action="Index">

<i class="bi bi-cart"></i>
<span>POS</span>

</a>
</li>


<!-- Products -->
<li class="nav-item">

<a class="nav-link d-flex justify-content-between align-items-center"
   data-bs-toggle="collapse"
   href="#productMenu">

<span>
<i class="bi bi-box"></i>
Products
</span>

<i class="bi bi-chevron-down"></i>

</a>

<div class="collapse @(productOpen ? "show" : "")" id="productMenu">

<ul class="nav flex-column ms-3">

<li class="nav-item">
<a class="nav-link @(controller=="Product"?"active":"")"
   asp-controller="Product"
   asp-action="Product">
Product List
</a>
</li>

<li class="nav-item">
<a class="nav-link @(controller=="ProductCategory"?"active":"")"
   asp-controller="ProductCategory"
   asp-action="ProductCategory">
Product Category
</a>
</li>

</ul>

</div>

</li>


<!-- Sales -->
<li class="nav-item">
<a class="nav-link @(controller=="Sales"?"active":"")"
   asp-controller="Sales"
   asp-action="Index">

<i class="bi bi-cash"></i>
<span>Sales</span>

</a>
</li>

</ul>

</div>

<!-- ================= PAGE CONTENT ================= -->
<div class="flex-grow-1 p-3">
@RenderBody()
</div>

</div>


<!-- ================= SCRIPTS ================= -->

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

@RenderSection("Scripts", required: false)

<script>

document.getElementById("toggleSidebar").onclick = function(){

    var sidebar = document.getElementById("sidebar");

    sidebar.classList.toggle("collapsed");

}

</script>

</body>
</html>