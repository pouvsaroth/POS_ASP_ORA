<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/POS_ASP_ORA.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-light bg-white shadow-sm px-3">

        <!-- Logo + Title -->
        <div class="d-flex align-items-center">
            <img src="~/images/vorakchuncoffeelogo.png" alt="Logo" style="height:40px; width:40px; object-fit:cover;" class="me-2" />
            <span class="fw-bold">Vorakchun Coffee</span>
        </div>

        <!-- Right Side -->
        <div class="dropdown">
            <a class="dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                Admin
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
                <li>
                    <a class="dropdown-item" href="/Account/Logout">Logout</a>
                </li>
            </ul>
        </div>

    </nav>

    <!-- Main Layout -->
    <div class="d-flex">

        <!-- Sidebar -->
        <div class="bg-light border-end p-3" style="width: 220px; height: 100vh;">
            <h5>Menu</h5>
            <ul class="nav flex-column">
                <li class="nav-item"><a class="nav-link">Dashboard</a></li>
                <li class="nav-item"><a class="nav-link active text-primary">POS</a></li>
                <li class="nav-item"><a class="nav-link">Sales</a></li>
                <li class="nav-item"><a class="nav-link">Products</a></li>
            </ul>
        </div>

        <!-- Content -->
        <div class="flex-grow-1 p-3">
            @RenderBody()
        </div>

    </div>
</body>
</html>
