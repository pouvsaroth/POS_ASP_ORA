@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - Vorakchun Coffee</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            height: 100vh;
        }

        .left-panel {
            background-color: #6b2f00;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

            .left-panel img {
                width: 120px;
                height: 120px;
                border-radius: 50%;
                margin-bottom: 20px;
            }

        .brand-text {
            font-family: cursive;
            font-size: 28px;
        }

        .right-panel {
            background-color: #f5f5f5;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-box {
            width: 350px;
        }

        .login-title {
            text-align: center;
            color: #6b2f00;
            margin-bottom: 20px;
        }

        .btn-login {
            background-color: green;
            color: white;
        }

        .btn-cancel {
            background-color: #c25a00;
            color: white;
        }

        .register-link {
            margin-top: 40px;
            color: white;
            text-decoration: underline;
        }
    </style>
</head>

<body>
    <div class="container-fluid h-100">
        <div class="row h-100">

            <!-- LEFT SIDE -->
            <div class="col-md-6 left-panel">
                <img src="~/images/vorakchuncoffeelogo.png" alt="Logo" />
                <div class="brand-text">Vorak Chun Coffee</div>

                <a href="#" class="register-link">Register your account</a>
            </div>

            <!-- RIGHT SIDE -->
            <div class="col-md-6 right-panel">
                <div class="login-box">

                    <h2 class="login-title">Login</h2>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <input name="username" class="form-control" placeholder="User name" required />
                        </div>

                        <div class="mb-3">
                            <input name="password" type="password" class="form-control" placeholder="Password" required />
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="reset" class="btn btn-cancel w-45">Cancel</button>
                            <button type="submit" class="btn btn-login w-45">Login</button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</body>
</html>
