@model IEnumerable<Category>
@section Scripts {

    <script src="~/js/product_category.js"></script>

}


<div class="d-flex justify-content-between align-items-center mb-3">
    <!-- Search Bar -->
    <div>
        <input type="text" id="searchBar" class="form-control" placeholder="Search categories..." />
    </div>

    <!-- Add and Delete Buttons -->
    <div>
        <button class="btn btn-brown me-2" id="btnAddCategory" data-bs-toggle="modal" data-bs-target="#categoryModal">
            Add
        </button>
        <button class="btn btn-danger" id="deleteSelected">
            Delete
        </button>
    </div>
</div>

<table id="categoryTable" class="table">
    <thead>
        <tr>
            <th><input type="checkbox" id="selectAll" /></th>
            <th style="display:none">ID</th>
            <th>Category Name</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>
                    <input type="checkbox" class="row-checkbox" value="@category.Id" />
                </td>
                <td style="display:none">@category.Id</td>
                <td>@category.CategoryName</td>
                <td>
                    <input type="checkbox" disabled @(category.Status == 1 ? "checked" : "") />
                </td>
                <td>
                    <button class="btn btn-warning btn-sm edit-btn" data-id="@category.Id" data-name="@category.CategoryName" data-status="@category.Status">
                        <i class="bi bi-pencil"></i>
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="modal fade" id="categoryModal">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">

            <div class="modal-header modal-brown">
                <h5 class="modal-title" id="categoryModalTitle">Add Category</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <form id="categoryForm" method="post">
                    <!-- Hidden input for ID -->
                    <input type="hidden" id="categoryId" name="Id" />

                    <div class="mb-3">
                        <label class="form-label">Category Name*</label>
                        <input id="categoryName" name="CategoryName" class="form-control" />
                    </div>

                    <div class="form-check">
                        <input type="checkbox" id="statusCheck" name="Status" value="1" class="form-check-input" checked>
                        <label class="form-check-label" for="statusCheck">
                            Active
                        </label>
                    </div>

                    <button type="submit" class="btn btn-brown">
                        Save
                    </button>
                </form>

            </div>

        </div>
    </div>
</div>