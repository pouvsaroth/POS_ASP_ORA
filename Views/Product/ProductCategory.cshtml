@model IEnumerable<Category>
@section Scripts {

    <script src="~/js/product_category.js"></script>

}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<h3>Category List</h3>

<button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#categoryModal">
    Add Category
</button>

<table id="categoryTable" class="table table-bordered">

    <thead>
        <tr>
            <th>ID</th>
            <th>Category Name</th>
            <th>Status</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.CategoryName</td>
                <td>@item.Status</td>
            </tr>
        }

    </tbody>

</table>

<div class="modal fade" id="categoryModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header modal-brown">
                <h5 class="modal-title">Add Category</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <form asp-action="Create" method="post">

                    <div class="mb-3">
                        <label class="form-label">Category Name</label>
                        <input name="CategoryName" class="form-control" />
                    </div>

                    <input type="hidden" name="Status" value="0" />

                    <div class="form-check">
                        <input type="checkbox" name="StatusCheck" value="true" class="form-check-input" id="statusCheck" checked>
                        <label class="form-check-label" for="statusCheck">
                            Active
                        </label>
                    </div>

                    <button type="submit" class="btn btn-brown">
                        Save
                    </button>

                </form>

            </div>

        </div>
    </div>
</div>