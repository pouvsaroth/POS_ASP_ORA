@model IEnumerable<POS_ASP_ORA.Models.MenuModel>

@{
    ViewData["Title"] = "Menu";
}

@section Scripts {
    <script src="~/js/menu.js"></script>
}

<div class="d-flex justify-content-between align-items-center mb-3">

    <!-- Search -->
    <div>
        <input type="text" id="searchBar" class="form-control" placeholder="Search menu..." />
    </div>

    <!-- Buttons -->
    <div>
        <button class="btn btn-brown me-2" id="btnAddMenu" data-bs-toggle="modal" data-bs-target="#menuModal">
            Add
        </button>
        <button class="btn btn-danger" id="deleteSelected">
            Delete
        </button>
    </div>

</div>

<table id="menuTable" class="table">
    <thead>
        <tr>
            <th><input type="checkbox" id="selectAll" /></th>
            <th>ID</th>
            <th>Menu</th>
            <th>Controller</th>
            <th>Action</th>
            <th>Icon</th>
            <th>Order</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>
                    <input type="checkbox" class="row-checkbox" value="@m.Id" />
                </td>
                <td>@m.Id</td>
                <td>
                    @if (m.MenuLevel == 1)
                    {
                        <strong>@m.MenuName</strong>
                    }
                    else
                    {
                        @Html.Raw(string.Concat(Enumerable.Repeat("&nbsp;&nbsp;&nbsp;&nbsp;", m.MenuLevel - 1)) + "↳ " + m.MenuName)
                    }
                </td>
                <td>@m.ControllerName</td>
                <td>@m.ActionName</td>
                <td><i class="@m.Icon"></i></td>
                <td>@m.DisplayOrder</td>

                <td>
                    <button class="btn btn-warning btn-sm edit-btn"
                            data-id="@m.Id"
                            data-name="@m.MenuName"
                            data-controller="@m.ControllerName"
                            data-action="@m.ActionName"
                            data-icon="@m.Icon"
                            data-order="@m.DisplayOrder"
                            data-parent="@m.ParentId">
                        <i class="bi bi-pencil"></i>
                    </button>

                    <button class="btn btn-danger btn-sm delete-btn"
                            data-id="@m.Id">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- MODAL -->
<div class="modal fade" id="menuModal">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">

            <div class="modal-header modal-brown">
                <h5 class="modal-title" id="menuModalTitle">Add Menu</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <form id="menuForm" method="post">

                    <input type="hidden" id="menuId" name="Id" />
                    <div class="mb-3">
                        <label class="form-label">Parent Menu</label>
                        <select id="parentId" name="ParentId" class="form-control">
                            <option value="">-- No Parent --</option>
                            @foreach (var p in Model)
                            {
                                <option value="@p.Id">
                                    @(new string('-', (p.MenuLevel - 1) * 2)) @p.MenuName
                                </option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Menu Name*</label>
                        <input id="menuName" name="MenuName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Controller</label>
                        <input id="controllerName" name="ControllerName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Action</label>
                        <input id="actionName" name="ActionName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Icon</label>
                        <input id="icon" name="Icon" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Display Order</label>
                        <input id="displayOrder" name="DisplayOrder" type="number" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-brown">
                        Save
                    </button>

                </form>

            </div>

        </div>
    </div>
</div>