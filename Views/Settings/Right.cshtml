@model List<POS_ASP_ORA.Models.RightModel>
@{
    ViewData["Title"] = "User Rights";
}

@section Scripts {
    <script src="~/js/right.js"></script>
}

<div class="container-fluid">

    <div class="row">

        <!-- ========================= -->
        <!-- ✅ LEFT: GROUP -->
        <!-- ========================= -->
        <div class="col-md-3 border-end">

            <h5>Group</h5>

            <!-- ADD GROUP -->
            <div class="d-flex mb-2">
               
                <button class="btn btn-primary" id="btnOpenAddGroup">Add</button>
            </div>

            <!-- GROUP LIST -->
            <ul class="list-group" id="groupList">
                @foreach (var g in Model)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center group-item"
                        data-id="@g.GroupId">

                        <span class="group-name">@g.GroupName</span>

                        <div>
                            <button class="btn btn-sm btn-warning edit-group" data-id="@g.GroupId" data-name="@g.GroupName">✏️</button>
                            <button class="btn btn-sm btn-danger delete-group" data-id="@g.GroupId">🗑</button>
                        </div>
                    </li>
                }
            </ul>

        </div>


        <!-- ========================= -->
        <!-- ✅ RIGHT: MENU -->
        <!-- ========================= -->
        <div class="col-md-9">

            <h5>Menu Rights</h5>

            <!-- Hidden Group ID -->
            <input type="hidden" id="groupId" />

            <!-- MENU LIST -->
            <div id="menuContainer" class="border rounded p-3" style="min-height:400px;">

                <p class="text-muted">Select a group to load menus...</p>

            </div>

            <!-- SAVE BUTTON -->
            <div class="mt-3 text-end">
                <button id="btnSave" class="btn btn-success">
                    💾 Save Rights
                </button>
            </div>

        </div>

    </div>

</div>

<!-- GROUP MODAL -->
<div class="modal fade" id="groupModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="groupModalTitle">Add Group</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="modalGroupId" />

                <div class="mb-3">
                    <label>Group Name</label>
                    <input type="text" id="groupNameInput" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Remark</label>
                    <input type="text" id="remarkInput" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Company</label>
                    <select id="companyIdInput" class="form-control">
                       
                    </select>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-success" id="btnSaveGroup">Save</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>

        </div>
    </div>
</div>