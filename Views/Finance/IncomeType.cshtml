@model IEnumerable<POS_ASP_ORA.Models.IncomeType>

@section Scripts {
    <script src="~/js/incometype.js"></script>
}

<div class="d-flex justify-content-between mb-3">
    <div>
        <input type="text" id="searchBar" class="form-control w-25" placeholder="Search..." />
    </div>
    <div>
        <button class="btn btn-brown me-2" id="btnAddIncomeType" data-bs-toggle="modal" data-bs-target="#incometypeModal">
            Add
        </button>
        <button class="btn btn-danger" id="deleteSelected">
            Delete
        </button>
    </div>
</div>

<table class="table" id="incometypeTable">
    <thead>
        <tr>
            <th><input type="checkbox" id="selectAll" /></th>
            <th>ID</th>
            <th>TypeName</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var incomeType in Model)
        {
            <tr>
                <td><input type="checkbox" class="row-checkbox" value="@incomeType.Id" /></td>
                <td>@incomeType.Id</td>
                <td>@incomeType.TypeName</td>
                <td><input type="checkbox" disabled @(incomeType.Status == 1 ? "checked" : "") /></td>
                <td>
                    <button class="btn btn-warning btn-sm edit-btn"
                            data-id="@incomeType.Id"
                            data-name="@incomeType.TypeName"
                            data-status="@incomeType.Status">
                        <i class="bi bi-pencil"></i>
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Modal -->
<div class="modal fade" id="incometypeModal">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <div class="modal-header modal-brown">
                <h5 class="modal-title" id="incometypeModalTitle">Add Income Type</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="incometypeForm" method="post">
                    <input type="hidden" id="incometypeId" name="Id" />

                    <div class="mb-3">
                        <label class="form-label">IncomeType Name*</label>
                        <input id="incometypeName" name="TypeName" class="form-control" />
                    </div>

                    <div class="form-check">
                        <input type="checkbox" id="statusCheck" name="Status" value="1" class="form-check-input" checked>
                        <label class="form-check-label" for="statusCheck">Active</label>
                    </div>

                    <button type="submit" class="btn btn-brown">Save</button>
                </form>
            </div>
        </div>
    </div>
</div>