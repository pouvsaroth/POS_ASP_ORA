@model IEnumerable<Purchase>

@section Scripts {
    <script src="~/js/purchase_order.js" asp-append-version="true"></script>
}

<div class="d-flex justify-content-between mb-3">
    <input type="text" id="searchPurchase" class="form-control w-25" placeholder="Search purchase..." />

    <div>
        <button class="btn btn-brown me-2" id="btnAddPurchaseOrder" data-bs-toggle="modal" data-bs-target="#purchaseModal">
            Add
        </button>
        <button class="btn btn-danger" id="deleteSelected">
            Delete
        </button>
    </div>
</div>

<table id="purchaseOrderTable" class="table">
    <thead>
        <tr>
            <th><input type="checkbox" id="selectAll" /></th>
            <th style="display:none">ID</th>
            <th>Bill No</th>
            <th>Date</th>
            <th>Supplier</th>
            <th>Total</th>
            <th>Paid</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var p in Model)
            {
                <tr>
                    <td>
                        <input type="checkbox" class="row-checkbox" value="@p.Id" />
                    </td>
                    <td style="display:none">@p.Id</td>
                    <td>@p.BillNo</td>
                    <td>@p.PurchaseDate.ToString("yyyy-MM-dd")</td>
                    <td>@p.SupplierName</td>
                    <td>@p.Total</td>
                    <td>@p.Paid</td>
                    <td>
                        @(p.Status == 1 ? "Paid" : p.Status == 2 ? "Partial" : "Unpaid")
                    </td>
                    <td>
                        <button class="btn btn-warning btn-sm edit-btn" data-id="@p.Id">
                            <i class="bi bi-pencil"></i>
                        </button>
                    </td>
                </tr>
            }
        } 
    </tbody>
</table>

<!-- MODAL -->
<div class="modal fade" id="purchaseModal">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header modal-brown">
                <h5 class="modal-title">Add Purchase</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">
                <form id="purchaseForm">

                    <div class="row">

                        <!-- FULL WIDTH -->
                        <div class="col-md-12">

                            <!-- HEADER ROW -->
                            <div class="row">
                                <div class="col-md-4">
                                    <label>Bill No</label>
                                    <input type="text" id="billNo" class="form-control" readonly />
                                </div>

                                <div class="col-md-4">
                                    <label>Supplier*</label>
                                    <select id="supplierId" class="form-control"></select>
                                </div>

                                <div class="col-md-4">
                                    <label>Purchase Date*</label>
                                    <input type="text" id="purchaseDate" class="form-control" />
                                </div>
                            </div>

                            <!-- ADD ROW BUTTON -->
                            <button type="button" class="btn btn-primary btn-sm my-2" id="btnAddRow">
                                + Add Row
                            </button>

                            <!-- TABLE -->
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Qty</th>
                                        <th>Product Unit</th>
                                        <th>Unit</th>
                                        <th>UnitPrice</th>
                                        <th>Discount</th>
                                        <th>VAT</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody id="purchaseItems"></tbody>
                            </table>

                            <!-- ✅ SUMMARY BELOW TABLE -->
                            <div class="justify-content-end">
                                <div style="border:2px dashed #ccc; padding:15px; border-radius:10px; background:#f8f9fa;">

                                    <label class="fw-bold">Summary</label>
                                    <hr/>
                                    <div class="row">
                                        <div class="col-md-2">
                                            <label>Subtotal</label>
                                            <input type="text" id="subtotal" class="form-control" readonly />
                                        </div>

                                        <div class="col-md-2">
                                            <label>Discount</label>
                                            <input type="number" id="discount" class="form-control" value="0" />
                                        </div>

                                        <div class="col-md-2">
                                            <label>Total</label>
                                            <input type="text" id="total" class="form-control fw-bold" readonly />
                                        </div>

                                        <div class="col-md-2">
                                            <label>Paid</label>
                                            <input type="number" id="paid" class="form-control" value="0" />
                                        </div>

                                        <div class="col-md-2">
                                            <label>Balance</label>
                                            <input type="text" id="balance" class="form-control text-danger" readonly />
                                        </div>
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- FOOTER -->
                    <div class="text-end mt-3">
                        <button type="button" class="btn btn-brown" id="savePurchase">Save</button>
                        <button type="button" class="btn btn-warning" id="saveAndPay">Save & Pay</button>
                    </div>

                </form>
            </div>

        </div>
    </div>
</div>