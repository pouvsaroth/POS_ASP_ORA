@model IEnumerable<Purchase>

@section Scripts {
    <script src="~/js/purchase.js" asp-append-version="true"></script>
}

<div class="d-flex justify-content-between mb-3">
    <input type="text" id="searchPurchase" class="form-control w-25" placeholder="Search purchase..." />

    <div>
        <button class="btn btn-brown" data-bs-toggle="modal" data-bs-target="#purchaseModal">
            Add Purchase
        </button>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Bill No</th>
            <th>Date</th>
            <th>Supplier</th>
            <th>Total</th>
            <th>Paid</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var p in Model)
            {
                <tr>
                    <td>@p.BillNo</td>
                    <td>@p.PurchaseDate.ToString("yyyy-MM-dd")</td>
                    <td>@p.SupplierName</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">No Data</td>
            </tr>
        }
    </tbody>
</table>

<!-- MODAL -->
<div class="modal fade" id="purchaseModal">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header modal-brown">
                <h5 class="modal-title">Add Purchase</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">
                <form id="purchaseForm">

                    <div class="row">

                        <!-- COLUMN 1 -->
                        <div class="col-md-4">

                            <div class="mb-3">
                                <label>Supplier*</label>
                                <select id="supplierId" class="form-control"></select>
                            </div>

                            <div class="mb-3">
                                <label>Bill No</label>
                                <input type="text" id="billNo" class="form-control" />
                            </div>

                            <div class="mb-3">
                                <label>Purchase Date*</label>
                                <input type="date" id="purchaseDate" class="form-control" />
                            </div>

                        </div>

                        <!-- COLUMN 2 -->
                        <div class="col-md-4">

                            <div class="mb-3">
                                <label>Search Product</label>
                                <input type="text" id="searchProduct" class="form-control" placeholder="Search or scan..." />
                            </div>

                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th width="70">Qty</th>
                                        <th width="90">Cost</th>
                                        <th width="90">Total</th>
                                        <th width="40"></th>
                                    </tr>
                                </thead>
                                <tbody id="purchaseItems"></tbody>
                            </table>

                        </div>

                        <!-- COLUMN 3 (SUMMARY like your IMAGE BOX) -->
                        <div class="col-md-4 text-center">

                            <label class="form-label">Summary</label>

                            <div style="width:100%; border:2px dashed #ccc; border-radius:10px; padding:15px; background:#f8f9fa;">

                                <div class="mb-2">
                                    <label>Subtotal</label>
                                    <input type="text" id="subtotal" class="form-control" readonly />
                                </div>

                                <div class="mb-2">
                                    <label>Discount</label>
                                    <input type="number" id="discount" class="form-control" value="0" />
                                </div>

                                <div class="mb-2">
                                    <label>Total</label>
                                    <input type="text" id="total" class="form-control fw-bold" readonly />
                                </div>

                                <div class="mb-2">
                                    <label>Paid</label>
                                    <input type="number" id="paid" class="form-control" value="0" />
                                </div>

                                <div class="mb-2">
                                    <label>Balance</label>
                                    <input type="text" id="balance" class="form-control text-danger" readonly />
                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- FOOTER -->
                    <div class="text-end mt-3">
                        <button type="button" class="btn btn-brown" id="savePurchase">Save</button>
                        <button type="button" class="btn btn-warning" id="saveAndPay">Save & Pay</button>
                    </div>

                </form>
            </div>

        </div>
    </div>
</div>