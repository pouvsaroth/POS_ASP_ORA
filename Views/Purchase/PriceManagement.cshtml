@model IEnumerable<POS_ASP_ORA.Models.PriceManagementModel>

@section Scripts {
    <script src="~/js/price_management.js" asp-append-version="true"></script>
}

<div class="d-flex justify-content-between align-items-center mb-3">

    <div>
        <input type="text" id="searchBar" class="form-control" placeholder="Search product price..." />
    </div>

    <div>
        <button class="btn btn-brown me-2"
                id="addBtn"
                data-bs-toggle="modal"
                data-bs-target="#priceModal">
            Add
        </button>

        <button class="btn btn-danger" id="deleteSelected">
            Delete
        </button>
    </div>

</div>

<table id="priceTable" class="table">

    <thead>
        <tr>
            <th><input type="checkbox" id="selectAll" /></th>
            <th style="display:none">ID</th>
            <th>Product</th>
            <th>Sale Price</th>
            <th>Currency</th>
            <th>Changed Date</th>
            <th>Changed By</th>
            <th>Remark</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>
                    <input type="checkbox" class="row-checkbox" value="@item.Id" />
                </td>

                <td style="display:none">@item.Id</td>
                <td>@item.ProductName</td>
                <td>@item.SalePrice</td>
                <td>@item.CurrencyName</td>
                <td>@item.ChangedDate.ToString("yyyy-MM-dd")</td>
                <td>@item.ChangedBy</td>
                <td>@item.Remark</td>

                <td>

                    <button class="btn btn-warning btn-sm edit-btn"
                            data-id="@item.Id"
                            data-product="@item.ProductId"
                            data-price="@item.SalePrice"
                            data-currency="@item.CurrencyId"
                            data-changedby="@item.ChangedBy"
                            data-remark="@item.Remark"
                            data-bs-toggle="modal"
                            data-bs-target="#priceModal">

                        <i class="bi bi-pencil"></i>

                    </button>

                </td>

            </tr>
        }

    </tbody>

</table>

<!-- Modal -->

<div class="modal fade" id="priceModal">

    <div class="modal-dialog modal-dialog-centered modal-md">

        <div class="modal-content">

            <div class="modal-header modal-brown">

                <h5 class="modal-title" id="priceModalTitle">Add Product Price</h5>

                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>

            </div>

            <div class="modal-body">

                <form id="priceForm" method="post" asp-action="Create">

                    <input type="hidden" id="priceId" name="Id" />

                    <div class="mb-3">
                        <label class="form-label">Product*</label>
                        <select id="ProductId" name="ProductId" class="form-control" required>
                            <option value=""></option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Sale Price*</label>
                        <input id="SalePrice" name="SalePrice" class="form-control" type="number" step="0.01" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Currency</label>
                        <select id="CurrencyId" name="CurrencyId" class="form-control">
                            <option value=""></option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Changed By</label>
                        <input id="ChangedBy" name="ChangedBy" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Remark</label>
                        <input id="Remark" name="Remark" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-brown">Save</button>

                </form>

            </div>

        </div>

    </div>

</div>